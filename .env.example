# Faber Code - runtime de IA (RWKV local + opcional Gemini API)

# Provedor padrão: rwkv | gemini | sambanova | custom:<id>
AI_PROVIDER=rwkv

# Timeouts de inferência (ms)
AI_REQUEST_TIMEOUT_MS=900000
BRAIN_BRIEFING_TIMEOUT_MS=1200000
BRAIN_PLAN_MAX_ELAPSED_MS=900000
BRAIN_PLAN_MAX_ATTEMPTS=3

# Perfil de execução
TIME_AS_COMPUTE_PROFILE=rapido

# RWKV local
RWKV_ENABLED=true
RWKV_MODEL_PATH=/caminho/para/seu-modelo-rwkv
RWKV_TOKENIZER_PATH=models/rwkv/tokenizer.json
RWKV_STRATEGY=cpu fp16
RWKV_MAX_NEW_TOKENS=80
RWKV_TEMPERATURE=0.2
RWKV_TOP_P=0.9
RWKV_V7_ON=1
RWKV_JIT_ON=0
RWKV_CUDA_ON=0

# Gemini API (opcional)
GEMINI_MODEL_BRAIN=gemini-2.0-flash
GEMINI_MAX_REQUESTS_PER_MINUTE=6
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# MemPalace (opcional)
MEMPALACE_PYTHON_BIN=python3
# MEMPALACE_PALACE_PATH=
# MEMPALACE_HOME=

# Cortex / RAG (opcional)
CORTEX_RAG_ENABLED=true
CORTEX_RAG_PROVIDER=r2r
R2R_BASE_URL=http://127.0.0.1:7272
R2R_SEARCH_LIMIT=6
R2R_STATUS_TIMEOUT_MS=3500
R2R_TIMEOUT_MS=12000
# R2R_API_KEY=
# Endpoint JSON configurável para indexar a biblioteca do Cortex no RAG.
# R2R_CORTEX_INGEST_ENDPOINT=/v3/documents

# SambaNova API (opcional)
SAMBANOVA_API_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL_BRAIN=Meta-Llama-3.1-8B-Instruct
SAMBANOVA_MIN_REQUEST_INTERVAL_MS=10000
SAMBANOVA_MAX_REQUESTS_PER_MINUTE=6
# SAMBANOVA_API_KEY=

# Qualidade pós-execução / auto-reparo
POST_EXEC_QUALITY_ENABLED=true
POST_EXEC_QUALITY_ENFORCE_ERRORS=true
POST_EXEC_QUALITY_ENFORCE_WARNINGS=false
EXECUTION_ENFORCE_EFFECT_GATE=true
EXECUTION_ENFORCE_NONZERO_DIFF_ON_EDIT=true
AUTO_REPAIR_ENABLED=true
AUTO_REPAIR_MAX_PASSES=2
