# Copie este arquivo para:
# ~/Library/Application Support/Faber Code/.env
#
# O app empacotado aberto pelo Finder nao herda variaveis do terminal.
# Por isso, segredos de runtime devem ficar neste .env externo ao .app.

AI_PROVIDER=mock

# Conta/backend local do Faber Code
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fabercode
FABER_SESSION_SECRET=troque-por-um-segredo-longo-com-32-ou-mais-caracteres
FABER_APP_BASE_URL=http://127.0.0.1:37418
FABER_BACKEND_HOST=127.0.0.1
FABER_BACKEND_PORT=37418
FABER_POSTGRES_SSL=false

# Login por email/senha local.
# Se quiser usar codigos dev por email, habilite apenas em ambiente local.
FABER_AUTH_DEV_CODES=false

# OAuth opcional
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:37418/auth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://127.0.0.1:37418/auth/github/callback

# IA remota opcional
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# SAMBANOVA_API_KEY=
